{
  "name": "@agent-ix/ix",
  "description": "The Agent IX unified CLI binary.",
  "version": "0.6.0",
  "type": "module",
  "bin": {
    "ix": "./bin/ix.js"
  },
  "files": [
    "bin/",
    "dist/",
    "oclif.manifest.json"
  ],
  "oclif": {
    "bin": "ix",
    "dirname": "ix",
    "commands": "./dist/commands",
    "plugins": [
      "@agent-ix/workflow-cli-plugin",
      "@agent-ix/workflow-definitions"
    ],
    "hooks": {
      "init": "./dist/hooks/init"
    },
    "topicSeparator": " ",
    "topics": {
      "local": {
        "description": "Manage the local Agent IX cluster (init, up, halt, status, list, admin-reset, auth, cluster)."
      },
      "local cluster": {
        "description": "Cluster lifecycle subcommands (down, stop, start, status)."
      },
      "elements": {
        "description": "Element discovery, scaffolding, and tap management."
      },
      "elements tap": {
        "description": "Manage element tap sources (add, remove, list)."
      },
      "config": {
        "description": "Read and write per-plugin configuration (get, set, edit, doctor)."
      },
      "secrets": {
        "description": "Manage plugin secrets in the OS keyring or age-encrypted fallback (list, set, rm, which)."
      },
      "tunnel": {
        "description": "Cloudflare Tunnel subcommands for exposing apps externally (up, down, status, domain, expose, unexpose)."
      }
    }
  },
  "scripts": {
    "build": "vite build && oclif manifest",
    "lint": "eslint \"src/**/*.ts\" --no-error-on-unmatched-pattern \"tests/**/*.ts\" && pnpm run format:check",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run --passWithNoTests",
    "clean": "rm -rf dist coverage oclif.manifest.json"
  },
  "dependencies": {
    "@agent-ix/ix-cli-core": "workspace:*",
    "@agent-ix/ix-cli-elements": "workspace:*",
    "@agent-ix/ix-cli-local": "workspace:*",
    "@agent-ix/ix-ui-cli": ">=0.4.5",
    "@agent-ix/workflow-cli-plugin": ">=0.1.0-0",
    "@agent-ix/workflow-core": ">=0.1.0-0",
    "@agent-ix/workflow-definitions": ">=0.1.0-0",
    "@oclif/core": ">=4.10.6",
    "picocolors": ">=1.1.1",
    "react": ">=18.3.1",
    "zod": ">=4.0.0"
  },
  "devDependencies": {
    "@types/react": ">=18.3.12",
    "oclif": "^4.23.0",
    "vite": ">=6.3.4",
    "vite-plugin-dts": ">=4.5.3",
    "vitest": ">=3.1.2"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/agent-ix/ix-cli.git"
  }
}
